# Lyzr API Key (required for agent calls)
LYZR_API_KEY=your-lyzr-api-key-here

# Optional: Agent ID (can also be set per-component)
AGENT_ID=your-agent-id-here

# AI provider switch: lyzr | openai_compatible
AI_PROVIDER=lyzr

# OpenAI-compatible local provider settings (used when AI_PROVIDER=openai_compatible)
LOCAL_LLM_BASE_URL=http://localhost:11434
LOCAL_LLM_API_KEY=
LOCAL_LLM_MODEL=llama3.1
